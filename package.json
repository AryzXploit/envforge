{
  "name": "envforge",
  "version": "1.0.0",
  "description": "zero-dependency config manager with validation, hot reload, auto secret masking & CLI tools. stops config bugs before they hit prod.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "envforge": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/test/*.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "config",
    "env",
    "environment",
    "configuration",
    "hot-reload",
    "validation",
    "secrets",
    "typescript",
    "zero-dependency",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0"
  }
}
